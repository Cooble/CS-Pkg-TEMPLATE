{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 19,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base-clang-linux",
      "description": "Base configuration for Clang on Linux x64",
      "hidden": true,
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "base-clang",
      "description": "Base configuration for Clang-cl on Windows x64",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl.exe",
        "CMAKE_CXX_COMPILER": "clang-cl.exe"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "base-msvc",
      "description": "Base configuration for MSVC on Windows x64",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_CXX_COMPILER": "cl.exe"
      }
    },
    {
      "name": "debug-linux-clang",
      "displayName": "Clang Linux Debug",
      "inherits": "base-clang-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release-linux-clang",
      "displayName": "Clang Linux Release",
      "inherits": "base-clang-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "debug64",
      "displayName": "Clang x64 Debug",
      "inherits": "base-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS_DEBUG": "/Od /Zi /RTC1",
        "CMAKE_C_FLAGS_DEBUG": "/Od /Zi /RTC1"
      }
    },
    {
      "name": "release64",
      "displayName": "Clang x64 Release",
      "inherits": "base-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "debug64msvc",
      "displayName": "MSVC x64 Debug",
      "inherits": "base-msvc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS_DEBUG": "/Od /Zi /RTC1",
        "CMAKE_C_FLAGS_DEBUG": "/Od /Zi /RTC1"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "Clang Linux Debug",
      "configurePreset": "debug-linux-clang"
    },
    {
      "name": "Clang Linux Release",
      "configurePreset": "release-linux-clang"
    },
    {
      "name": "Debug",
      "configurePreset": "debug64"
    },
    {
      "name": "Release",
      "configurePreset": "release64"
    },
    {
      "name": "Debug MSVC",
      "configurePreset": "debug64msvc"
    }
  ]
}
